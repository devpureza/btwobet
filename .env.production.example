# Copie para .env.production na EC2 (nunca commite o arquivo real)
APP_NAME="Bolão Copa 2026"
BOLAO_ENTRY_FEE_BRL=50
APP_URL=https://btwobet.click
DOMAIN=btwobet.click
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=btwobet
DB_USERNAME=btwobet
DB_PASSWORD=troque-por-senha-forte

# Primeiro deploy: true para criar usuários de teste; depois volte para false
RUN_SEED=false

# Caddy expõe 80/443; nginx fica só na rede interna do Compose
